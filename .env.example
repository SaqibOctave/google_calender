PORT=4000
NODE_ENV=development

# Service account credentials (from the JSON key file downloaded in Google Cloud Console)
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIExampleKeyContentsHere\n-----END PRIVATE KEY-----\n"

# The calendar the service account has been given "Make changes to events" access to
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Scheduling rules
TIMEZONE=Asia/Kolkata
BUSINESS_START_HOUR=9
BUSINESS_END_HOUR=18
SLOT_DURATION_MINUTES=30
